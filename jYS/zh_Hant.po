msgstr "[{prc}% 信賴區間]"

#: R/mcor.b.R
msgid "{ciWidth}% CI Lower"
msgstr "{ciWidth}% 信賴區間下界"

#: R/mcor.b.R
msgid "{ciWidth}% CI Upper"
msgstr "{ciWidth}% 信賴區間上界"

#: R/mlr.b.R
msgid "{k}-Fold CV"
msgstr "{k} 折交叉驗證"

#: R/mui.b.R
msgid "{varType} proposed decision"
msgstr "{varType} 建議決策"

#: R/mmf.b.R
